{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Product Guide",
  "description": "ByteMate Docs",
  "colors": {
    "primary": "#8C78FF",
    "light": "#8C78FF",
    "dark": "#8C78FF"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "fontawesome"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "directory": "card",
    "languages": [
      {
        "language": "pl",
        "default": true,
        "groups": [
          {
            "group": "updates",
            "pages": [
              "untitled-page"
            ]
          }
        ]
      },
      {
        "language": "en",
        "groups": [
          {
            "group": "updates",
            "pages": [
              "en/untitled-page"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient"
  },
  "fonts": {
    "family": "Figtree"
  }
}
