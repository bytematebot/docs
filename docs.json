{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Product Guide",
  "description": "ByteMate Docs",
  "colors": {
    "primary": "#8C78FF",
    "light": "#8C78FF",
    "dark": "#8C78FF"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "fontawesome"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "directory": "card",
    "groups": [
      {
        "group": "updates",
        "pages": [
          "untitled-page"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/images/bytemate_logo.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient"
  },
  "fonts": {
    "family": "Figtree"
  }
}
